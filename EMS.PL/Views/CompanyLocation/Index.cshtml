@using EMS.DAL.Entities.Location
@model CompanyLocation

<div class="content-wrapper container mt-4">
    <h3>Set Company Location</h3>

   @*  {{!-- Search Box --}} *@
    <div class="input-group mb-2">
        <input type="text" id="searchInput" class="form-control"
               placeholder="Search for a location..." />
        <button class="btn btn-outline-secondary" type="button" id="searchBtn">
            <i class="fas fa-search"></i> Search
        </button>
    </div>
    <div id="searchResults" class="list-group mb-2" style="display:none; position:absolute; z-index:1000; width:calc(100% - 3rem);"></div>

    <div id="map" style="height: 450px;"></div>

    <form method="post" asp-action="Save" class="mt-3">
        <input type="hidden" id="Latitude" name="Latitude" value="@Model.Latitude" />
        <input type="hidden" id="Longitude" name="Longitude" value="@Model.Longitude" />
        <div class="mb-3">
            <label>Location Name</label>
            <input type="text" id="locationName" name="Name" class="form-control" value="@Model.Name" />
        </div>
        <div class="mb-3">
            <label>Allowed Radius (Meters)</label>
            <input type="number" id="radius" name="AllowedRadiusMeters"
                   class="form-control" value="@Model.AllowedRadiusMeters" />
        </div>
        <button class="btn btn-primary">Save</button>
    </form>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script>
        // ─── Init map ───────────────────────────────────────────────────────────────
        var lat = @Model.Latitude  == 0 ? 30.0444 : @Model.Latitude;
        var lng = @Model.Longitude == 0 ? 31.2357 : @Model.Longitude;

        var map    = L.map('map').setView([lat, lng], 15);
        var marker = L.marker([lat, lng], { draggable: true }).addTo(map);
        var circle = L.circle([lat, lng], {
            radius: parseFloat(document.getElementById('radius').value) || 0,
            color: '#3388ff', fillOpacity: 0.15
        }).addTo(map);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);

        // ─── Shared helper: move marker + circle + update inputs ────────────────────
        function moveToPosition(newLat, newLng, displayName) {
            var latlng = L.latLng(newLat, newLng);
            marker.setLatLng(latlng);
            circle.setLatLng(latlng);
            map.setView(latlng, 15);

            document.getElementById('Latitude').value  = newLat;
            document.getElementById('Longitude').value = newLng;

            if (displayName) {
                document.getElementById('locationName').value = displayName;
            }
        }

        // ─── Drag marker ────────────────────────────────────────────────────────────
        marker.on('dragend', function () {
            var pos = marker.getLatLng();
            moveToPosition(pos.lat, pos.lng, null);
        });

        // ─── Click map ──────────────────────────────────────────────────────────────
        map.on('click', function (e) {
            moveToPosition(e.latlng.lat, e.latlng.lng, null);
        });

        // ─── Radius change ──────────────────────────────────────────────────────────
        document.getElementById('radius').addEventListener('input', function () {
            circle.setRadius(parseFloat(this.value) || 0);
        });

        // ─── Search ─────────────────────────────────────────────────────────────────
        var searchInput   = document.getElementById('searchInput');
        var searchBtn     = document.getElementById('searchBtn');
        var searchResults = document.getElementById('searchResults');

        // Nominatim geocode call
        async function geocode(query) {
            if (!query.trim()) return;

            searchBtn.disabled = true;
            searchBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

            try {
                var url = 'https://nominatim.openstreetmap.org/search'
                        + '?format=json&limit=5&addressdetails=1&q='
                        + encodeURIComponent(query);

                var res  = await fetch(url, {
                    headers: { 'Accept-Language': 'en', 'User-Agent': 'EMS-Location-App' }
                });
                var data = await res.json();

                renderResults(data);
            } catch (err) {
                searchResults.innerHTML =
                    '<span class="list-group-item text-danger">Search failed. Please try again.</span>';
                searchResults.style.display = 'block';
            } finally {
                searchBtn.disabled = false;
                searchBtn.innerHTML = '<i class="fas fa-search"></i> Search';
            }
        }

        // Render dropdown results
        function renderResults(results) {
            searchResults.innerHTML = '';

            if (!results.length) {
                searchResults.innerHTML =
                    '<span class="list-group-item text-muted">No results found.</span>';
                searchResults.style.display = 'block';
                return;
            }

            results.forEach(function (r) {
                var item = document.createElement('button');
                item.type      = 'button';
                item.className = 'list-group-item list-group-item-action';
                item.textContent = r.display_name;

                item.addEventListener('click', function () {
                    moveToPosition(parseFloat(r.lat), parseFloat(r.lon), r.display_name);
                    searchInput.value          = r.display_name;
                    searchResults.style.display = 'none';
                });

                searchResults.appendChild(item);
            });

            searchResults.style.display = 'block';
        }

        // Trigger on button click
        searchBtn.addEventListener('click', function () {
            geocode(searchInput.value);
        });

        // Trigger on Enter key
        searchInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); geocode(this.value); }
        });

        // Close dropdown on outside click
        document.addEventListener('click', function (e) {
            if (!searchResults.contains(e.target) && e.target !== searchInput) {
                searchResults.style.display = 'none';
            }
        });
    </script>
}