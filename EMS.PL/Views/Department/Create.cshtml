@using EMS.BLL.Models.Dto.DepartmentDto
@model DepartmentViewModel
@{
    ViewData["Title"] = "Create Department";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card-panel p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="m-0"><i class="bi bi-plus-circle me-2"></i> Create Department</h4>
            <a asp-action="Index" class="btn btn-outline-light">Back</a>
        </div>

        <form method="post" asp-controller="Department" asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <partial name="PartialView/_CreateAndUpdate" />

            <div class="text-end mt-4">
                <button type="submit" class="btn btn-create px-4">
                    <i class="bi bi-save2 me-1"></i> Save
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
