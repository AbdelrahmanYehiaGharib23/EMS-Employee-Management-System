@model DepartmentDetailsDto
@{
    ViewData["Title"] = "Delete Department";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card-panel p-4 text-center">
        <h4 class="text-danger mb-3">Delete Department</h4>

        <div class="alert alert-warning w-75 mx-auto">
            Are you sure you want to delete
            <strong>@Model.Name</strong> ?
        </div>

        <form asp-action="Delete" method="post" asp-route-id="@Model.Id" class="mt-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger px-4">
                <i class="bi bi-trash3-fill me-1"></i> Confirm Delete
            </button>

            <a asp-action="Index" class="btn btn-outline-light px-4 ms-2">Cancel</a>
        </form>
    </div>
</div>
