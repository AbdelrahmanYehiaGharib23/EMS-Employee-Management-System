@model DepartmentDetailsDto
@{
    ViewData["Title"] = "Department Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card-panel p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="m-0"><i class="bi bi-building me-2"></i> Department Details</h4>
            <a asp-action="Index" class="btn btn-outline-light">Back</a>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <label class="form-label text-light">Name</label>
                <input class="form-control bg-dark text-light border-secondary" value="@Model.Name" readonly />
            </div>

            <div class="col-md-6">
                <label class="form-label text-light">Code</label>
                <input class="form-control bg-dark text-light border-secondary" value="@Model.Code" readonly />
            </div>

            <div class="col-12">
                <label class="form-label text-light">Description</label>
                <textarea class="form-control bg-dark text-light border-secondary" rows="3" readonly>@Model.Description</textarea>
            </div>

            <div class="col-md-6">
                <label class="form-label text-light">Created By</label>
                <input class="form-control bg-dark text-light border-secondary" value="@Model.CreatedBy" readonly />
            </div>

            <div class="col-md-6">
                <label class="form-label text-light">Created On</label>
                <input class="form-control bg-dark text-light border-secondary" value="@Model.CreatedOn" readonly />
            </div>
        </div>

        <div class="mt-4 text-end">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-create me-2">Edit</a>
            <a asp-action="Index" class="btn btn-outline-light">Back</a>
        </div>
    </div>
</div>
