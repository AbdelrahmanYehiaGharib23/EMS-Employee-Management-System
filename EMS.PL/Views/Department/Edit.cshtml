@model DepartmentViewModel
@{
    ViewData["Title"] = "Edit Department";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card-panel p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="m-0"><i class="bi bi-pencil-square me-2"></i> Edit @Model.Name</h4>
            <a asp-action="Index" class="btn btn-outline-light">Back</a>
        </div>

        <form method="post" asp-controller="Department" asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <partial name="PartialView/_CreateAndUpdate" />

            <div class="text-end mt-4">
                <button type="submit" class="btn btn-create px-4">
                    <i class="bi bi-save2 me-1"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
