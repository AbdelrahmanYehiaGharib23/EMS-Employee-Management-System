@model EmployeeDetailsDto

@{
    ViewData["Title"] = "Delete Employee";
}

<div class="container mt-4">
    <div class="card-panel p-4 text-center">
        <h4 class="text-danger mb-3">Delete Employee</h4>

        <div class="alert alert-warning w-75 mx-auto">
            <strong>Are you sure you want to delete this employee?</strong>
        </div>

        <div class="mt-3 text-start mx-auto w-75">
            <dl class="row">
                <dt class="col-sm-3 text-light">Name</dt>
                <dd class="col-sm-9 text-light">@Model.Name</dd>

                <dt class="col-sm-3 text-light">Email</dt>
                <dd class="col-sm-9 text-light">@Model.Email</dd>

                <dt class="col-sm-3 text-light">Department</dt>
                <dd class="col-sm-9 text-light">@Model.DepartmentName</dd>

                <dt class="col-sm-3 text-light">Salary</dt>
                <dd class="col-sm-9 text-light">@Model.Salary.ToString("C")</dd>
            </dl>
        </div>

        <form method="post" asp-action="DeleteConfirmed" asp-controller="Employee" asp-route-id="@Model.Id" class="mt-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger me-2 px-4">
                <i class="fas fa-trash me-1"></i> Delete
            </button>
            <a asp-controller="Employee" asp-action="Index" class="btn btn-outline-light px-4">
                <i class="fas fa-arrow-left me-1"></i> Cancel
            </a>
        </form>
    </div>
</div>

