
@model IEnumerable<UserViewModel>
@{
    ViewData["Title"] = "Users";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="content-wrapper">
        <div class="section-header">
            <h2 class="m-0"><i class="fa-solid fa-user me-2"></i> Users</h2>
            <div class="d-flex align-items-center gap-2">
                <a asp-action="Create" class="btn btn-create shadow-sm"><i class="fa-solid fa-plus me-1"></i> Add User</a>
            </div>
        </div>

        <div class="search-row">
            <form asp-action="Index" method="get" class="d-flex w-100">
                <input name="email" class="form-control search-input" type="text" placeholder="User's Name" />
                <button type="submit" class="btn btn-outline-success btn-search">Search</button>
            </form>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="table-container p-3">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-light table-dark-theme">
                        <thead>
                            <tr>
                                <th>FirstName</th>
                                <th>LastName</th>
                                <th>UserName</th>
                                <th>Email</th>
                                <th>Roles</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>@user.FirstName</td>
                                    <td>@user.LastName</td>
                                    <td>@user.UserName</td>
                                    <td>@user.Email</td>
                                    <td>@string.Join(",", user.Roles ?? Enumerable.Empty<string>())</td>
                                    <td class="text-center">
                                        <div class="d-inline-flex gap-1">
                                            <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-light" title="Details"><i class="bi bi-eye text-info"></i></a>
                                            <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-light" title="Edit"><i class="bi bi-pencil-square text-warning"></i></a>
                                            <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-custom text-center mt-4 shadow-sm rounded-4">No users found.</div>
        }
    </div>
</div>


