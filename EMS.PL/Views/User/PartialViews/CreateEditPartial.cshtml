@using EMS.PL.ViewModels.Identity
@model UserViewModel



<div class="form-group mb-3">
    <label asp-for="Id" class="form-label text-light"></label>
    <input readonly class="form-control bg-dark text-light border-secondary" asp-for="Id" />
</div>
<div class="form-group mb-3">
    <label asp-for="FirstName" class="form-label text-light"></label>
    <input class="form-control bg-dark text-light border-secondary" asp-for="FirstName" />
    <span class="text-danger " asp-validation-for="FirstName"></span>
</div>

<div class="form-group mb-3">
    <label asp-for="LastName" class="form-label text-light"></label>
    <input class="form-control bg-dark text-light border-secondary" asp-for="LastName" />
    <span class="text-danger " asp-validation-for="LastName"></span>
</div>
<div class="form-group mb-3">
    <label asp-for="UserName" class="form-label text-light"></label>
    <input readonly class="form-control bg-dark text-light border-secondary" asp-for="UserName" />
</div>
<div class="form-group mb-3">
    <label asp-for="Email" class="form-label text-light"></label>
    <input readonly class="form-control bg-dark text-light border-secondary" asp-for="Email" />
</div>

